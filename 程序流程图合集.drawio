        <mxCell id="1" parent="0" />
        <mxCell id="PyzcG41c8JIGcuHcHwQH-1" parent="1" style="text;whiteSpace=wrap;html=1;fontFamily=宋体;" value="&lt;div style=&quot;background-color:#131314;color:#ebebeb&quot;&gt;&lt;pre style=&quot;font-family:&#39;JetBrains Mono&#39;,monospace;font-size:11.3pt;&quot;&gt;&lt;span style=&quot;color:#ed864a;&quot;&gt;create table &lt;/span&gt;t_kb_file&lt;br&gt;(&lt;br&gt;    file_id          &lt;span style=&quot;color:#ed864a;&quot;&gt;int auto_increment comment &lt;/span&gt;&lt;span style=&quot;color:#54b33e;&quot;&gt;&#39;&lt;/span&gt;&lt;span style=&quot;color:#54b33e;font-family:&#39;Courier New&#39;,monospace;&quot;&gt;文件&lt;/span&gt;&lt;span style=&quot;color:#54b33e;&quot;&gt;id&#39;&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;color:#54b33e;&quot;&gt;        &lt;/span&gt;&lt;span style=&quot;color:#ed864a;&quot;&gt;primary key&lt;/span&gt;&lt;span style=&quot;color:#ed864a;font-weight:bold;&quot;&gt;,&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;color:#ed864a;font-weight:bold;&quot;&gt;    &lt;/span&gt;kb_id            &lt;span style=&quot;color:#ed864a;&quot;&gt;int                                  not null comment &lt;/span&gt;&lt;span style=&quot;color:#54b33e;&quot;&gt;&#39;&lt;/span&gt;&lt;span style=&quot;color:#54b33e;font-family:&#39;Courier New&#39;,monospace;&quot;&gt;所属知识库&lt;/span&gt;&lt;span style=&quot;color:#54b33e;&quot;&gt;id&#39;&lt;/span&gt;&lt;span style=&quot;color:#ed864a;font-weight:bold;&quot;&gt;,&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;color:#ed864a;font-weight:bold;&quot;&gt;    &lt;/span&gt;file_name        &lt;span style=&quot;color:#ed864a;&quot;&gt;varchar&lt;/span&gt;(&lt;span style=&quot;color:#33ccff;font-weight:bold;&quot;&gt;255&lt;/span&gt;)                         &lt;span style=&quot;color:#ed864a;&quot;&gt;not null comment &lt;/span&gt;&lt;span style=&quot;color:#54b33e;&quot;&gt;&#39;&lt;/span&gt;&lt;span style=&quot;color:#54b33e;font-family:&#39;Courier New&#39;,monospace;&quot;&gt;文件名&lt;/span&gt;&lt;span style=&quot;color:#54b33e;&quot;&gt;&#39;&lt;/span&gt;&lt;span style=&quot;color:#ed864a;font-weight:bold;&quot;&gt;,&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;color:#ed864a;font-weight:bold;&quot;&gt;    &lt;/span&gt;file_path        &lt;span style=&quot;color:#ed864a;&quot;&gt;varchar&lt;/span&gt;(&lt;span style=&quot;color:#33ccff;font-weight:bold;&quot;&gt;512&lt;/span&gt;)                         &lt;span style=&quot;color:#ed864a;&quot;&gt;not null comment &lt;/span&gt;&lt;span style=&quot;color:#54b33e;&quot;&gt;&#39;&lt;/span&gt;&lt;span style=&quot;color:#54b33e;font-family:&#39;Courier New&#39;,monospace;&quot;&gt;文件存储路径&lt;/span&gt;&lt;span style=&quot;color:#54b33e;&quot;&gt;&#39;&lt;/span&gt;&lt;span style=&quot;color:#ed864a;font-weight:bold;&quot;&gt;,&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;color:#ed864a;font-weight:bold;&quot;&gt;    &lt;/span&gt;file_size        &lt;span style=&quot;color:#ed864a;&quot;&gt;bigint                               null comment &lt;/span&gt;&lt;span style=&quot;color:#54b33e;&quot;&gt;&#39;&lt;/span&gt;&lt;span style=&quot;color:#54b33e;font-family:&#39;Courier New&#39;,monospace;&quot;&gt;文件大小（字节）&lt;/span&gt;&lt;span style=&quot;color:#54b33e;&quot;&gt;&#39;&lt;/span&gt;&lt;span style=&quot;color:#ed864a;font-weight:bold;&quot;&gt;,&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;color:#ed864a;font-weight:bold;&quot;&gt;    &lt;/span&gt;uploader_user_id &lt;span style=&quot;color:#ed864a;&quot;&gt;int                                  not null comment &lt;/span&gt;&lt;span style=&quot;color:#54b33e;&quot;&gt;&#39;&lt;/span&gt;&lt;span style=&quot;color:#54b33e;font-family:&#39;Courier New&#39;,monospace;&quot;&gt;上传用户&lt;/span&gt;&lt;span style=&quot;color:#54b33e;&quot;&gt;id&#39;&lt;/span&gt;&lt;span style=&quot;color:#ed864a;font-weight:bold;&quot;&gt;,&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;color:#ed864a;font-weight:bold;&quot;&gt;    &lt;/span&gt;&lt;span style=&quot;color:#ed864a;&quot;&gt;status           tinyint&lt;/span&gt;(&lt;span style=&quot;color:#33ccff;font-weight:bold;&quot;&gt;1&lt;/span&gt;) &lt;span style=&quot;color:#ed864a;&quot;&gt;default &lt;/span&gt;&lt;span style=&quot;color:#33ccff;font-weight:bold;&quot;&gt;0                 &lt;/span&gt;&lt;span style=&quot;color:#ed864a;&quot;&gt;null comment &lt;/span&gt;&lt;span style=&quot;color:#54b33e;&quot;&gt;&#39;&lt;/span&gt;&lt;span style=&quot;color:#54b33e;font-family:&#39;Courier New&#39;,monospace;&quot;&gt;状态（&lt;/span&gt;&lt;span style=&quot;color:#54b33e;&quot;&gt;0=&lt;/span&gt;&lt;span style=&quot;color:#54b33e;font-family:&#39;Courier New&#39;,monospace;&quot;&gt;处理中，&lt;/span&gt;&lt;span style=&quot;color:#54b33e;&quot;&gt;1=&lt;/span&gt;&lt;span style=&quot;color:#54b33e;font-family:&#39;Courier New&#39;,monospace;&quot;&gt;成功，&lt;/span&gt;&lt;span style=&quot;color:#54b33e;&quot;&gt;2=&lt;/span&gt;&lt;span style=&quot;color:#54b33e;font-family:&#39;Courier New&#39;,monospace;&quot;&gt;失败）&lt;/span&gt;&lt;span style=&quot;color:#54b33e;&quot;&gt;&#39;&lt;/span&gt;&lt;span style=&quot;color:#ed864a;font-weight:bold;&quot;&gt;,&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;color:#ed864a;font-weight:bold;&quot;&gt;    &lt;/span&gt;is_deleted       &lt;span style=&quot;color:#ed864a;&quot;&gt;tinyint&lt;/span&gt;(&lt;span style=&quot;color:#33ccff;font-weight:bold;&quot;&gt;1&lt;/span&gt;) &lt;span style=&quot;color:#ed864a;&quot;&gt;default &lt;/span&gt;&lt;span style=&quot;color:#33ccff;font-weight:bold;&quot;&gt;0                 &lt;/span&gt;&lt;span style=&quot;color:#ed864a;&quot;&gt;null comment &lt;/span&gt;&lt;span style=&quot;color:#54b33e;&quot;&gt;&#39;&lt;/span&gt;&lt;span style=&quot;color:#54b33e;font-family:&#39;Courier New&#39;,monospace;&quot;&gt;逻辑删除标记（&lt;/span&gt;&lt;span style=&quot;color:#54b33e;&quot;&gt;0=&lt;/span&gt;&lt;span style=&quot;color:#54b33e;font-family:&#39;Courier New&#39;,monospace;&quot;&gt;未删除，&lt;/span&gt;&lt;span style=&quot;color:#54b33e;&quot;&gt;1=&lt;/span&gt;&lt;span style=&quot;color:#54b33e;font-family:&#39;Courier New&#39;,monospace;&quot;&gt;已删除）&lt;/span&gt;&lt;span style=&quot;color:#54b33e;&quot;&gt;&#39;&lt;/span&gt;&lt;span style=&quot;color:#ed864a;font-weight:bold;&quot;&gt;,&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;color:#ed864a;font-weight:bold;&quot;&gt;    &lt;/span&gt;created_at       &lt;span style=&quot;color:#ed864a;&quot;&gt;datetime   default CURRENT_TIMESTAMP null comment &lt;/span&gt;&lt;span style=&quot;color:#54b33e;&quot;&gt;&#39;&lt;/span&gt;&lt;span style=&quot;color:#54b33e;font-family:&#39;Courier New&#39;,monospace;&quot;&gt;创建时间&lt;/span&gt;&lt;span style=&quot;color:#54b33e;&quot;&gt;&#39;&lt;/span&gt;&lt;span style=&quot;color:#ed864a;font-weight:bold;&quot;&gt;,&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;color:#ed864a;font-weight:bold;&quot;&gt;    &lt;/span&gt;updated_at       &lt;span style=&quot;color:#ed864a;&quot;&gt;datetime   default CURRENT_TIMESTAMP null on update CURRENT_TIMESTAMP comment &lt;/span&gt;&lt;span style=&quot;color:#54b33e;&quot;&gt;&#39;&lt;/span&gt;&lt;span style=&quot;color:#54b33e;font-family:&#39;Courier New&#39;,monospace;&quot;&gt;更新时间&lt;/span&gt;&lt;span style=&quot;color:#54b33e;&quot;&gt;&#39;&lt;/span&gt;&lt;span style=&quot;color:#ed864a;font-weight:bold;&quot;&gt;,&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;color:#ed864a;font-weight:bold;&quot;&gt;    &lt;/span&gt;&lt;span style=&quot;color:#ed864a;&quot;&gt;constraint &lt;/span&gt;fk_kb_file_kb&lt;br&gt;        &lt;span style=&quot;color:#ed864a;&quot;&gt;foreign key &lt;/span&gt;(kb_id) &lt;span style=&quot;color:#ed864a;&quot;&gt;references &lt;/span&gt;t_knowledge_base (kb_id)&lt;span style=&quot;color:#ed864a;font-weight:bold;&quot;&gt;,&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;color:#ed864a;font-weight:bold;&quot;&gt;    &lt;/span&gt;&lt;span style=&quot;color:#ed864a;&quot;&gt;constraint &lt;/span&gt;fk_kb_file_user&lt;br&gt;        &lt;span style=&quot;color:#ed864a;&quot;&gt;foreign key &lt;/span&gt;(uploader_user_id) &lt;span style=&quot;color:#ed864a;&quot;&gt;references &lt;/span&gt;t_user (user_id)&lt;br&gt;)&lt;br&gt;    &lt;span style=&quot;color:#ed864a;&quot;&gt;comment &lt;/span&gt;&lt;span style=&quot;color:#54b33e;&quot;&gt;&#39;&lt;/span&gt;&lt;span style=&quot;color:#54b33e;font-family:&#39;Courier New&#39;,monospace;&quot;&gt;知识库文件表&lt;/span&gt;&lt;span style=&quot;color:#54b33e;&quot;&gt;&#39;&lt;/span&gt;&lt;span style=&quot;color:#ed864a;font-weight:bold;&quot;&gt;;&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;color:#ed864a;font-weight:bold;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/pre&gt;&lt;/div&gt;" vertex="1">
